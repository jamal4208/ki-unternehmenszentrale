# Airtable Pilot-Konfiguration fuer lokale Tests.
# AIRTABLE_PAT niemals in Frontend-Dateien eintragen.
# Echte Werte spaeter nur lokal in .env.local eintragen.
# .env.local darf nicht gesichert oder committed werden.
# AIRTABLE_ENABLE_CONNECTION_TEST bleibt standardmaessig false.
# V6.1.0: Airtable-Test-Base ist nur fuer Testdaten.
# Echte Werte nur in .env.local eintragen.
# .env.local niemals sichern oder committen.
# Connection-Test ist read-only.
# Keine Record-Felder werden ausgegeben.

PORT=4173
AIRTABLE_API_KEY=
AIRTABLE_API_TOKEN=
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_PROJECTS=
AIRTABLE_ENABLE_CONNECTION_TEST=false
AIRTABLE_FIRST_PREVIEW_TABLE_ID=
AIRTABLE_FIRST_READONLY_PREVIEW_APPROVED=false

# Nur lokal auf true setzen, wenn Jamal die erste read-only Minimalanzeige manuell freigibt.
